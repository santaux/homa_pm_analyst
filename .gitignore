# Metabase: ship the populated H2 DB so recipients get the dashboards
# pre-built, but skip transient lock/trace files that Metabase regenerates
# on every boot.
metabase/mb-data/**/*.lock.db
metabase/mb-data/**/*.trace.db
metabase/*.log

